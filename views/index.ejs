<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MineBBS自动签到 - 管理中心</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>MineBBS Auto Signin</h1>
            <div class="header-right">
                <a href="/settings" class="btn btn-secondary">设置</a>
                <a href="/logout" class="btn btn-danger">退出登录</a>
            </div>
        </div>
        
        <% if (message) { %>
            <div class="success-message"><%= message %></div>
        <% } %>
        
        <% if (error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>
        
        <!-- 定时时间设置 -->
        <div class="card">
            <h2>定时设置</h2>
            <form action="/set-time" method="post">
                <div class="form-group">
                    <label for="executeTime">每日签到时间 (HH:MM:SS)</label>
                    <input type="text" id="executeTime" name="executeTime" value="<%= executeTime %>" required pattern="([01]?[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]">
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">保存设置</button>
                </div>
            </form>
            
            <div class="action-buttons">
                <form action="/manual-signin" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-success">立即执行签到</button>
                </form>
            </div>
        </div>
        
        <!-- 账号管理 -->
        <div class="card">
            <h2>账号管理</h2>
            
            <!-- 添加账号表单 -->
            <div class="add-account-form">
                <h3>添加新账号</h3>
                <form action="/add-account" method="post">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="name">账号名称</label>
                            <input type="text" id="name" name="name" required>
                        </div>
                        <div class="form-group">
                            <label for="cookies">Cookies</label>
                            <input type="text" id="cookies" name="cookies" required>
                        </div>
                        <div class="form-group">
                            <label for="csrfToken">CSRF Token</label>
                            <input type="text" id="csrfToken" name="csrfToken" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">添加账号</button>
                    </div>
                </form>
            </div>
            
            <!-- 账号列表 -->
            <div class="accounts-list">
                <h3>已添加账号</h3>
                <% if (accounts.length === 0) { %>
                    <p class="no-accounts">暂无账号，请添加</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table>
                            <thead>
                                <tr>
                                    <th>账号名称</th>
                                    <th>Cookies</th>
                                    <th>CSRF Token</th>
                                    <th>操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% accounts.forEach(function(account, index) { %>
                                    <tr>
                                        <td><%= account.name %></td>
                                        <td class="truncate"><%= account.cookies %></td>
                                        <td class="truncate"><%= account.csrfToken %></td>
                                        <td>
                                            <button class="btn btn-secondary edit-btn" data-index="<%= index %>">编辑</button>
                                            <form action="/delete-account" method="post" style="display: inline;">
                                                <input type="hidden" name="id" value="<%= index %>">
                                                <button type="submit" class="btn btn-danger" onclick="return confirm('确定要删除这个账号吗？');">删除</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
        
        <!-- 编辑账号模态框 -->
        <div id="edit-modal" class="modal">
            <div class="modal-content">
                <span class="close-btn">&times;</span>
                <h3>编辑账号</h3>
                <form id="edit-form" action="/edit-account" method="post">
                    <input type="hidden" id="edit-id" name="id">
                    <div class="form-group">
                        <label for="edit-name">账号名称</label>
                        <input type="text" id="edit-name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="edit-cookies">Cookies</label>
                        <input type="text" id="edit-cookies" name="cookies" required>
                    </div>
                    <div class="form-group">
                        <label for="edit-csrfToken">CSRF Token</label>
                        <input type="text" id="edit-csrfToken" name="csrfToken" required>
                    </div>
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">保存修改</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <script>
        // 编辑账号模态框
        const modal = document.getElementById('edit-modal');
        const closeBtn = document.getElementsByClassName('close-btn')[0];
        const editBtns = document.getElementsByClassName('edit-btn');
        const accounts = <%- JSON.stringify(accounts) %>;
        
        // 打开模态框
        for (let i = 0; i < editBtns.length; i++) {
            editBtns[i].addEventListener('click', function() {
                const index = this.getAttribute('data-index');
                const account = accounts[index];
                
                document.getElementById('edit-id').value = index;
                document.getElementById('edit-name').value = account.name;
                document.getElementById('edit-cookies').value = account.cookies;
                document.getElementById('edit-csrfToken').value = account.csrfToken;
                
                modal.style.display = 'block';
            });
        }
        
        // 关闭模态框
        closeBtn.addEventListener('click', function() {
            modal.style.display = 'none';
        });
        
        // 点击模态框外部关闭
        window.addEventListener('click', function(event) {
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        });
    </script>
</body>
</html>